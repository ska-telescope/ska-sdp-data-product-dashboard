{
  "name": "ska-dataproduct-dashboard",
  "version": "0.13.0",
  "private": true,
  "type": "module",
  "repository": "git@gitlab.com:ska-telescope/ska-dataproduct-dashboard.git",
  "license": "BSD 3-Clause",
  "author": "",
  "scripts": {
    "build": "NODE_OPTIONS='--max_old_space_size=8192' vite build",
    "checker": "yarn && yarn prettier:fix && yarn lint:fix && yarn test:unit && yarn build",
    "dev": "ENV_TYPE_FILE=env_scripts/env_config ENV_JS_OUTPUT_LOCATION=public/env.js bash env_scripts/env_config.sh js && vite",
    "start": "ENV_TYPE_FILE=env_scripts/env_config ENV_JS_OUTPUT_LOCATION=public/env.js bash env_scripts/env_config.sh js && NODE_ENV=test vite",
    "preview": "vite preview",
    "code-analysis": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --ignore-path .eslintignore -f junit -o linting.xml",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "lint:tsc": "tsc --noEmit",
    "prettier": "prettier --check \"**/*\"",
    "prettier:fix": "prettier --write \"**/*\"",
    "skao:update": "yarn add @ska-telescope/ska-gui-components@latest @ska-telescope/ska-gui-local-storage@latest",
    "test:unit": "vitest run --no-file-parallelism --reporter=default --reporter=junit --outputFile=build/reports/unit-tests.xml --coverage.enabled=true --coverage.reportsDirectory=build/coverage",
    "test:unit:ui": "vitest --coverage.enabled=true --reporter=default --ui --api.host 127.0.0.1 --api.port 5174",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --config video=false",
    "test:cypress:e2e:ci": "cross-env cypress run --e2e --headless --browser chrome --reporter junit --reporter-options mochaFile=build/tests/e2e-tests[hash].xml",
    "test:coverage:report:ci": "npx nyc report --report-dir=build/reports --reporter=cobertura",
    "fix": "npm-run-all --continue-on-error \"fix:*\"",
    "fix:yarn-deduplicate": "yarn install && yarn-deduplicate --strategy=fewer && yarn install",
    "typecheck": "tsc --noEmit"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@azure/msal-browser": "^3.13.0",
    "@azure/msal-react": "^3.0.4",
    "@emotion/react": "^11.9.3",
    "@emotion/styled": "^11.9.3",
    "@mui/icons-material": "^5.15.3",
    "@mui/lab": "^5.0.0-alpha.159",
    "@mui/material": "^5.15.3",
    "@mui/system": "^5.15.3",
    "@mui/x-data-grid": "^7.22.2",
    "@mui/x-data-grid-generator": "^6.20.0",
    "@mui/x-date-pickers": "^7.2.0",
    "@react-spring/web": "^9.7.3",
    "@ska-telescope/ska-gui-components": "^2.2.14",
    "@ska-telescope/ska-gui-local-storage": "^2.0.4",
    "@ska-telescope/ska-login-page": "0.9.15",
    "@types/streamsaver": "^2.0.4",
    "axios": "^1.6.5",
    "cross-env": "^7.0.3",
    "downloadjs": "^1.4.7",
    "framer-motion": "^11.1.7",
    "i18next": "^23.11.2",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.5.1",
    "moment": "^2.30.1",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.1.1",
    "streamsaver": "^2.0.6",
    "typescript": "5.1.6"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.11.0",
    "@testing-library/cypress": "10.0.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^15.0.3",
    "@types/downloadjs": "^1.4.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "babel-plugin-transform-class-properties": "^6.24.1",
    "cypress": "^13.1.0",
    "cypress-vite": "^1.6.0",
    "eslint": "8.56.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-cypress": "^2.14.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.1.2",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-react": "^7.12.3",
    "eslint-plugin-react-hooks": "^4.6.0",
    "istanbul-lib-coverage": "^3.2.0",
    "@vitest/coverage-istanbul": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "happy-dom": "^17.0.0",
    "vitest": "^3.0.0",
    "msw": "^2.2.14",
    "npm-run-all": "^4.1.5",
    "nyc": "^15.1.0",
    "prettier": "3.2.5",
    "react-test-renderer": "^18.2.0",
    "sass": "^1.69.7",
    "vite": "^6.3.5",
    "vite-plugin-istanbul": "^7.1.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "packageManager": "yarn@1.22.22"
}
